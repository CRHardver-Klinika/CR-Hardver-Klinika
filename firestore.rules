rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isAdmin() { 
      return isVerified() && request.auth.token.email == "Cimpian.Robert.88@gmail.com"; 
    }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Validation Blueprints
    function isValidCustomer(data) {
      return data.keys().hasAll(['name', 'joinedAt']) 
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.joinedAt is timestamp;
    }

    function isValidDevice(data) {
      return data.keys().hasAll(['customerId', 'model', 'type', 'createdAt'])
        && data.customerId is string && isValidId(data.customerId)
        && data.model is string && data.model.size() <= 100
        && data.type in ['PC', 'Laptop', 'Console', 'Tablet', 'Other']
        && data.createdAt is timestamp;
    }

    function isValidServiceReport(data) {
      return data.keys().hasAll(['deviceId', 'status', 'updatedAt'])
        && data.deviceId is string && isValidId(data.deviceId)
        && data.status in ['received', 'diagnosing', 'waiting_parts', 'repairing', 'completed', 'delivered']
        && data.updatedAt is timestamp;
    }

    function isValidInventory(data) {
      return data.keys().hasAll(['partName', 'stock', 'updatedAt'])
        && data.partName is string && data.partName.size() <= 100
        && data.stock is number
        && data.updatedAt is timestamp;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['name', 'email', 'content', 'status', 'createdAt'])
        && data.name is string && data.name.size() <= 100
        && data.email is string && data.email.size() <= 100
        && data.content is string && data.content.size() <= 2000
        && data.status in ['new', 'read', 'archived']
        && data.createdAt is timestamp;
    }

    // MATCH BLOCKS

    match /customers/{customerId} {
      allow read, write: if isAdmin();
    }

    match /devices/{deviceId} {
      allow read, write: if isAdmin();
    }

    match /services/{serviceId} {
      allow read, write: if isAdmin();
    }

    match /inventory/{itemId} {
      allow read, write: if isAdmin();
    }

    match /messages/{messageId} {
      // Anyone can CREATE a message (contact form)
      allow create: if isValidMessage(incoming()) 
        && incoming().status == 'new'
        && incoming().createdAt == request.time;
      
      // Admin can read/manage all messages
      allow read, update, delete: if isAdmin();
    }
  }
}
