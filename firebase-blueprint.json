{
  "entities": {
    "Customer": {
      "title": "Customer",
      "description": "Information about a client",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Full name of the customer" },
        "email": { "type": "string", "format": "email", "description": "Contact email" },
        "phone": { "type": "string", "description": "Phone number" },
        "address": { "type": "string", "description": "Physical address" },
        "joinedAt": { "type": "string", "format": "date-time", "description": "Timestamp when the customer was added" }
      },
      "required": ["name", "joinedAt"]
    },
    "Device": {
      "title": "Device",
      "description": "A hardware device brought in for service",
      "type": "object",
      "properties": {
        "customerId": { "type": "string", "description": "ID of the customer who owns this device" },
        "model": { "type": "string", "description": "Brand and model (e.g., ASUS Laptop, Custom PC)" },
        "serialNumber": { "type": "string", "description": "Device serial number" },
        "type": { "type": "string", "enum": ["PC", "Laptop", "Console", "Tablet", "Other"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerId", "model", "type", "createdAt"]
    },
    "ServiceReport": {
      "title": "Service Report",
      "description": "Details of a service operation on a device",
      "type": "object",
      "properties": {
        "deviceId": { "type": "string", "description": "The target device" },
        "description": { "type": "string", "description": "What was done" },
        "status": { "type": "string", "enum": ["received", "diagnosing", "waiting_parts", "repairing", "completed", "delivered"] },
        "cost": { "type": "number" },
        "technicianNotes": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["deviceId", "status", "updatedAt"]
    },
    "Inventory": {
      "title": "Inventory",
      "description": "Stock of parts and consumables",
      "type": "object",
      "properties": {
        "partName": { "type": "string" },
        "sku": { "type": "string" },
        "stock": { "type": "number" },
        "price": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["partName", "stock", "updatedAt"]
    },
    "Message": {
      "title": "Message",
      "description": "Incoming inquiries from the website",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "subject": { "type": "string" },
        "content": { "type": "string" },
        "status": { "type": "string", "enum": ["new", "read", "archived"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "content", "status", "createdAt"]
    }
  },
  "firestore": {
    "customers": { "schema": "Customer", "description": "Directory of clients" },
    "devices": { "schema": "Device", "description": "List of hardware being serviced" },
    "services": { "schema": "ServiceReport", "description": "Timeline of service actions" },
    "inventory": { "schema": "Inventory", "description": "Parts warehouse" },
    "messages": { "schema": "Message", "description": "Website contact submissions" }
  }
}
